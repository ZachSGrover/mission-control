ENVIRONMENT=dev
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_USE_UTC=false
REQUEST_LOG_SLOW_MS=1000
REQUEST_LOG_INCLUDE_HEALTH=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mission_control
# For remote access, set this to your UI origin (e.g. http://<server-ip>:3000 or https://mc.example.com).
CORS_ORIGINS=http://localhost:3000
# REQUIRED for gateway provisioning/agent heartbeats. Must be reachable by gateway runtime.
BASE_URL=
# Security response headers (blank values disable each header).
SECURITY_HEADER_X_CONTENT_TYPE_OPTIONS=
SECURITY_HEADER_X_FRAME_OPTIONS=
SECURITY_HEADER_REFERRER_POLICY=
SECURITY_HEADER_PERMISSIONS_POLICY=

# Auth mode: clerk or local.
AUTH_MODE=local
# REQUIRED when AUTH_MODE=local (must be non-placeholder and at least 50 chars).
LOCAL_AUTH_TOKEN=
# Clerk (auth only; used when AUTH_MODE=clerk)
CLERK_SECRET_KEY=
CLERK_API_URL=https://api.clerk.com
CLERK_VERIFY_IAT=true
CLERK_LEEWAY=10.0
# Database
DB_AUTO_MIGRATE=false
# Generic RQ queue / dispatch settings
RQ_REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default
RQ_DISPATCH_THROTTLE_SECONDS=15.0
RQ_DISPATCH_MAX_RETRIES=3
GATEWAY_MIN_VERSION=2026.02.9

# ── Settings encryption ───────────────────────────────────────────────────────
# Dedicated key for encrypting API keys stored in DB. Decoupled from auth.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# If unset, falls back to LOCAL_AUTH_TOKEN / CLERK_SECRET_KEY (rotation-sensitive).
SETTINGS_ENCRYPTION_KEY=

# ── Extra CORS origins ────────────────────────────────────────────────────────
# Add additional frontend domains without overwriting CORS_ORIGINS.
EXTRA_CORS_ORIGINS=

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used by health-checks and Telegram webhook instructions.
# Defaults to first HTTPS entry in CORS_ORIGINS if not set.
FRONTEND_URL=

# ── OnlyFans Intelligence — OnlyMonster integration ───────────────────────────
# Local-dev fallback for the OnlyMonster API key.  In production / shared
# environments the key should be saved via the UI (Settings → Integrations →
# OnlyMonster), where it is encrypted with Fernet and stored in app_settings.
# The DB value always wins over this env var when both are present.
ONLYMONSTER_API_KEY=
# Base URL for the OnlyMonster REST API.  Override per environment if your
# vendor account uses a regional or staging host.  The live OpenAPI spec is
# served from https://omapi.onlymonster.ai/docs/json.
ONLYMONSTER_API_BASE_URL=https://omapi.onlymonster.ai
